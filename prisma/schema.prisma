// Sappura E-Commerce Database Schema
// Production Ready Version

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////
// ENUMS
//////////////////////////////

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum CollectionType {
  STANDARD
  SEASONAL
  PROMOTIONAL
  FEATURED
}

enum BannerType {
  HOME
  CATEGORY
  PRODUCT
  GLOBAL
}

enum BannerPosition {
  HERO
  ABOVE_FOOTER
  SIDEBAR
  POPUP
}

//////////////////////////////
// PRODUCTS
//////////////////////////////

model Product {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  sku           String?  @unique
  description   String   @db.Text

  price         Float
  originalPrice Float?

  category      String
  subcategory   String?

  // Legacy fields - kept for backward compatibility
  images        String[]
  video         String?

  // New media array structure
  media         Json[]   // Array of { type: "image" | "video", url: string, thumbnail?: string }
  
  // Collections system
  collections   String[] // Array of collection slugs (e.g., ["ramadan-offers", "featured"])
  
  // Product status and flags
  isFeatured    Boolean  @default(false)
  isBestSeller  Boolean  @default(false)
  isNewArrival   Boolean  @default(false)
  
  sizes         String[]
  colors        Json?
  variants      Json?
  tags          String[]

  stock         Int      @default(0)
  inStock       Boolean  @default(true)

  rating        Float    @default(0)
  reviewCount   Int      @default(0)

  features      String[]

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews       Review[]
  orderItems    OrderItem[]
  wishlists     Wishlist[]
  productCollections ProductCollection[]

  @@index([category])
  @@index([slug])
  @@index([collections])
  @@index([isFeatured])
  @@index([isBestSeller])
  @@index([isNewArrival])
}

//////////////////////////////
// COLLECTIONS
//////////////////////////////

model Collection {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?  @db.Text
  image         String?
  bannerImage   String?
  
  // Collection metadata
  type          CollectionType @default(STANDARD)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  
  // Display settings
  showInMenu    Boolean  @default(true)
  showOnHome    Boolean  @default(true)
  
  // SEO
  title         String?
  metaDescription String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  products      ProductCollection[]

  @@index([slug])
  @@index([type])
  @@index([isActive])
  @@index([sortOrder])
}

// Junction table for many-to-many relationship
model ProductCollection {
  id          String   @id @default(uuid())
  
  productId   String
  collectionId String
  
  sortOrder   Int      @default(0)
  
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection  Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
  @@index([collectionId])
  @@index([productId])
}

//////////////////////////////
// PROMOTIONS/BANNERS
//////////////////////////////

model Banner {
  id            String   @id @default(uuid())
  title         String
  subtitle      String?
  description   String?  @db.Text
  
  // Banner content
  imageUrl      String?
  mobileUrl     String?
  videoUrl      String?
  
  // Banner links
  linkUrl       String?
  linkText      String?
  collectionSlug String?
  
  // Display settings
  type          BannerType @default(HOME)
  position      BannerPosition @default(HERO)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  
  // Timing
  startDate     DateTime?
  endDate       DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([position])
  @@index([isActive])
  @@index([sortOrder])
}

//////////////////////////////
// NEWSLETTER SUBSCRIPTIONS
//////////////////////////////

model NewsletterSubscription {
  id          String   @id @default(uuid())
  email       String   @unique
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

//////////////////////////////
// CATEGORY
//////////////////////////////

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique

  description String?
  image       String?

  productCount Int     @default(0)

  createdAt   DateTime @default(now())

  @@index([slug])
}

//////////////////////////////
// CUSTOMER
//////////////////////////////

model Customer {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phone       String?
  
  verified    Boolean  @default(false)
  otp         String?
  otpExpiry   DateTime?

  address     String?  @db.Text
  city        String?
  postalCode  String?

  totalOrders Int      @default(0)
  totalSpent  Float    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]

  @@index([email])
}

//////////////////////////////
// ORDERS
//////////////////////////////

model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique

  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])

  customerName    String
  email           String
  phone           String

  address         String   @db.Text
  city            String
  postalCode      String?

  subtotal        Float
  shipping        Float    @default(0)
  tax             Float    @default(0)
  total           Float

  status          OrderStatus   @default(PENDING)
  paymentMethod   String        @default("COD")
  paymentStatus   PaymentStatus @default(UNPAID)

  notes           String?  @db.Text
  trackingNumber  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           OrderItem[]

  @@index([orderNumber])
  @@index([email])
  @@index([status])
}

//////////////////////////////
// ORDER ITEMS
//////////////////////////////

model OrderItem {
  id          String  @id @default(uuid())

  orderId     String
  productId   String?

  // Snapshot fields (important)
  productName String
  price       Float
  quantity    Int
  size        String?
  color       String?
  image       String?

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

//////////////////////////////
// REVIEWS
//////////////////////////////

model Review {
  id          String   @id @default(uuid())
  productId   String

  userName    String
  email       String?

  rating      Int
  comment     String   @db.Text

  verified    Boolean  @default(false)

  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

//////////////////////////////
// WISHLIST
//////////////////////////////

model Wishlist {
  id        String   @id @default(uuid())

  email     String
  productId String

  addedAt   DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([email, productId])
}

//////////////////////////////
// ADMIN USERS
//////////////////////////////

model User {
  id        String   @id @default(uuid())

  name      String
  email     String   @unique
  password  String

  role      UserRole @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

//////////////////////////////
// PASSWORD RESET
//////////////////////////////

model PasswordReset {
  id        String   @id @default(uuid())

  email     String
  token     String   @unique
  tokenHash String   @unique

  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([email])
}

//////////////////////////////
// COUPONS
//////////////////////////////

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique

  description   String?

  discountType  DiscountType
  discountValue Float

  maxUses       Int?
  usedCount     Int      @default(0)

  minAmount     Float    @default(0)

  validFrom     DateTime
  validUntil    DateTime

  active        Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
}

//////////////////////////////
// CAMPAIGNS
//////////////////////////////

model Campaign {
  id               String   @id @default(uuid())
  name             String
  bannerImage      String?
  startDate        DateTime
  endDate          DateTime
  discount         Float    @default(0)
  featuredProducts String[] @default([])
  isActive         Boolean  @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([startDate, endDate])
}

//////////////////////////////
// SHIPPING RULES
//////////////////////////////

model ShippingRule {
  id                   String   @id @default(uuid())
  region               String   @unique
  cost                 Float    @default(0)
  freeShippingThreshold Float?
  isActive             Boolean  @default(true)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

